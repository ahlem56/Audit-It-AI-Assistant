APP_NAME=Audit IT Assistant API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:4173

AUTH_ENABLED=false
AUTH_FRONTEND_BASE_URL=http://localhost:4173
AUTH_SESSION_COOKIE_NAME=audit_it_session
AUTH_SESSION_TTL_HOURS=12
AUTH_COOKIE_SECURE=false
AUTH_SQLITE_PATH=app/data/auth.sqlite3

# Entra External ID
# Use the metadata URL generated for the application associated with your sign-up/sign-in user flow.
# Example format:
# https://yourtenant.ciamlogin.com/yourtenant.onmicrosoft.com/v2.0/.well-known/openid-configuration?appid=YOUR_CLIENT_ID
AUTH_ENTRA_METADATA_URL=
AUTH_ENTRA_CLIENT_ID=
AUTH_ENTRA_CLIENT_SECRET=
AUTH_ENTRA_REDIRECT_URI=http://127.0.0.1:8000/auth/entra/callback
AUTH_ENTRA_POST_LOGOUT_REDIRECT_URI=http://localhost:4173/login

# Microsoft Graph delegated ingestion (SharePoint / Teams files / OneDrive).
# Use the same app registration as AUTH_ENTRA_* when you use delegated permissions.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
GRAPH_DELEGATED_SCOPES=User.Read Files.Read

# Optional local demo mode identity when AUTH_ENABLED=false
AUTH_DEMO_USER_EMAIL=demo.auditor@audit-it.local
AUTH_DEMO_USER_NAME=Demo Auditor
AUTH_DEMO_USER_ORGANIZATION=Audit IT Local Workspace

# Optional Azure SQL persistence.
# Keep false for local demos unless a reachable Azure SQL database is configured.
AZURE_SQL_ENABLED=false
AZURE_SQL_SERVER=
AZURE_SQL_DATABASE=
AZURE_SQL_USERNAME=
AZURE_SQL_PASSWORD=
